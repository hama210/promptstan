{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "promptstan-api",
  "main": "worker/index.js",
  "compatibility_date": "2026-07-08",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "promptstan-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PROMPT_IMAGES",
      "bucket_name": "promptstan-images"
    }
  ]
}
