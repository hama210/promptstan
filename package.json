{
  "name": "promptstan",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "worker:dev": "wrangler dev",
    "worker:check": "npm run build && wrangler deploy --dry-run",
    "worker:deploy": "npm run build && wrangler deploy --keep-vars",
    "db:schema": "wrangler d1 execute promptstan-db --file=database/schema.sql",
    "db:seed": "wrangler d1 execute promptstan-db --file=database/seed.sql",
    "db:migrate:local": "wrangler d1 migrations apply promptstan-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply promptstan-db --remote",
    "test": "node scripts/test-phase6.mjs && node scripts/test-automation.mjs && node scripts/test-growth-intelligence.mjs && node scripts/test-stabilization.mjs && node scripts/test-product-operations.mjs && node scripts/test-image-quality.mjs && node scripts/test-prompt-purge.mjs",
    "check": "npm test && npm run build && wrangler deploy --dry-run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "vite": "8.1.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "lucide-react": "1.24.0"
  },
  "devDependencies": {
    "wrangler": "4.111.0"
  }
}
