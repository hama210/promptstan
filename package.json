{
  "name": "promptstan",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "db:schema": "wrangler d1 execute promptstan-db --file=database/schema.sql",
    "db:seed": "wrangler d1 execute promptstan-db --file=database/seed.sql"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "lucide-react": "latest"
  },
  "devDependencies": {
    "wrangler": "latest"
  }
}
